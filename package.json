{
  "name": "mvp",
  "type": "module",
  "version": "0.4.0",
  "engines": {
    "node": ">=18.17.1"
  },
  "description": "The elementary.io Website http://elementary.io",
  "dependencies": {
    "cssnano": "^8.0.2",
    "glob": "^13.0.6",
    "gulp": "^5.0.0",
    "gulp-cached": "^1.1.1",
    "gulp-changed": "^5.0.4",
    "gulp-imagemin": "^9.2.0",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-rev": "^12.0.0",
    "postcss-preset-env": "^11.3.2",
    "scriptjs": "^2.5.9",
    "webpack": "^5.108.4",
    "webpack-manifest-plugin": "^6.0.1"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.7.0",
    "gulp-cli": "^3.0.0",
    "@csstools/stylelint-formatter-github": "^2.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0"
  },
  "scripts": {
    "install:submodule": "git submodule init && git submodule update --force --rebase",
    "install:composer": "cd _backend && composer install",
    "postinstall": "npm run install:composer",
    "lint": "sh _tests/css.sh && sh _tests/javascript.sh && sh _tests/php.sh",
    "build": "gulp",
    "build:images": "gulp images:rebuild",
    "start": "php -S 0.0.0.0:8000 router.php",
    "watch": "gulp watch"
